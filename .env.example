# Mapbox (browser)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Earth Engine (API routes) — use ONE of the options below

# Option A (recommended): path to the JSON key file (gitignored)
# GOOGLE_APPLICATION_CREDENTIALS=secrets/gee-service-account.json
# npm run gee:install-key -- ~/Downloads/your-key.json

# Option B: full service account JSON as a single line
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Option B: full JSON in GEE_PRIVATE_KEY (no other GEE_* required for auth)
# GEE_PRIVATE_KEY={"type":"service_account","client_email":"...@....iam.gserviceaccount.com",...}

# Option C: IAM service account email + PEM (use \n for newlines inside the key string)
# GEE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GEE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Project id for ee.initialize (optional if JSON includes project_id)
EARTH_ENGINE_PROJECT=
# Alias:
# GEE_PROJECT_ID=

# Hosting timeouts (e.g. DigitalOcean 504): production uses a lighter EE path by default.
# EE_FULL_COMPUTE=1  → full charts, storm map tiles, storm disturbed km², longer NDVI history (slower)
# EE_FAST_MODE=0     → disable fast path in production (heavier compute; may 504 on small instances)
